<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>For Gannu 💕</title>
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;700&family=Fredoka:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.4/dist/confetti.browser.min.js"></script>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    min-height: 100vh; width: 100%;
    font-family: "Fredoka", sans-serif;
    background: linear-gradient(135deg, #fff1f2 0%, #fdf2f8 50%, #fff7ed 100%);
    color: #881337; overflow-x: hidden;
  }
  .caveat { font-family: "Caveat", cursive; }
  ::selection { background: #fda4af; color: #7f1d1d; }

  .screen {
    position: fixed; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 24px; text-align: center;
    opacity: 0; pointer-events: none;
    transition: opacity .6s ease;
    overflow: hidden;
  }
  .screen.active { opacity: 1; pointer-events: auto; }

  /* --- Screen 1 --- */
  #opening h1 {
    font-family: "Caveat", cursive;
    font-size: clamp(56px, 8vw, 96px);
    color: #e11d48;
    animation: fadeUp .7s .2s both;
  }
  #opening p.sub {
    margin-top: 20px; color: #f472b6;
    animation: fadeUp .7s .5s both;
    font-size: 18px;
  }
  #opening p.hint {
    margin-top: 32px; color: #fda4af;
    font-size: 12px; letter-spacing: 2px;
    animation: fadeUp .7s 1.6s both;
  }
  .hii-btn {
    margin-top: 48px;
    padding: 20px 56px; border: none; cursor: pointer;
    border-radius: 999px; background: #f43f5e; color: #fff;
    font-family: "Fredoka", sans-serif; font-size: 22px; font-weight: 600;
    box-shadow: 0 10px 30px -8px rgba(244,63,94,.6);
    animation: popIn .8s .9s both;
    transition: transform .2s, background .2s;
  }
  .hii-btn:hover { background: #e11d48; transform: scale(1.08) rotate(2deg); }
  .hii-btn:active { transform: scale(0.95); }

  /* --- Screen 2 --- */
  #question .title {
    font-family: "Caveat", cursive;
    font-size: clamp(48px, 6vw, 84px);
    color: #e11d48; line-height: 1.05;
    display: flex; flex-wrap: wrap; justify-content: center; gap: 4px 20px;
    max-width: 800px;
  }
  #question .title .w {
    display: inline-block; animation: floatWord 3.5s ease-in-out infinite;
  }
  #question .title .w:nth-child(1){ animation-delay: 0s; }
  #question .title .w:nth-child(2){ animation-delay: .3s; animation-duration: 3.8s; }
  #question .title .w:nth-child(3){ animation-delay: .6s; animation-duration: 4.2s; }
  #question .title .w:nth-child(4){ animation-delay: .9s; animation-duration: 3.6s; }
  #question .title .forever {
    flex-basis: 100%;
    font-style: italic; color: #ec4899;
    filter: drop-shadow(0 4px 12px rgba(236,72,153,.35));
    animation: pulseWord 2.6s ease-in-out infinite;
  }

  .buttons-row {
    margin-top: 56px; position: relative;
    display: flex; align-items: center; justify-content: center;
    gap: 56px; width: 100%; max-width: 640px; height: 160px;
  }
  .yes-btn {
    padding: 16px 42px; border: none; cursor: pointer;
    border-radius: 999px; background: #f43f5e; color: #fff;
    font-family: "Fredoka", sans-serif; font-size: 20px; font-weight: 600;
    box-shadow: 0 10px 30px -8px rgba(244,63,94,.6);
    transition: transform .3s cubic-bezier(.34,1.56,.64,1), background .2s;
  }
  .yes-btn:hover { background: #e11d48; }
  .no-btn {
    padding: 16px 42px; border: 1px solid #fecdd3; cursor: pointer;
    border-radius: 999px; background: rgba(255,255,255,.7); color: #f43f5e;
    font-family: "Fredoka", sans-serif; font-size: 20px; font-weight: 600;
    backdrop-filter: blur(6px); box-shadow: 0 6px 20px -8px rgba(244,63,94,.35);
    transition: transform .35s cubic-bezier(.34,1.56,.64,1);
  }
  .song-hint { margin-top: 40px; font-size: 12px; color: #fda4af; }

  .sparkle { position: absolute; color: #f472b6; animation: spin 12s linear infinite; }
  .sparkle.two { color: #fbbf24; animation-duration: 10s; animation-direction: reverse; }

  /* --- Tease Bubbles --- */
  .bubble-layer {
    position: absolute; inset: 0; pointer-events: none;
    display: flex; align-items: center; justify-content: center;
  }
  .bubble {
    position: absolute; padding: 12px 20px;
    border-radius: 18px; color: #fff;
    font-weight: 600; font-size: 15px; max-width: 260px;
    box-shadow: 0 10px 30px -8px rgba(244,63,94,.5);
    animation: bubblePop 2.5s ease-out forwards;
  }
  .bubble::after {
    content: ""; position: absolute; bottom: -6px; left: 50%;
    width: 14px; height: 14px; transform: translateX(-50%) rotate(45deg);
    background: inherit;
  }

  /* --- Screen 3 --- */
  #celebration h1 {
    font-family: "Caveat", cursive;
    font-size: clamp(52px, 7vw, 84px);
    color: #e11d48;
    animation: fadeDown .7s .2s both;
  }
  #celebration .msg {
    margin-top: 8px; font-family: "Caveat", cursive;
    font-size: clamp(28px, 3.5vw, 42px);
    color: #ec4899;
    animation: fadeUp .7s .6s both;
  }
  #celebration .gif-wrap {
    margin-top: 40px; position: relative;
    animation: popRotate .9s .9s cubic-bezier(.34,1.56,.64,1) both;
  }
  #celebration .gif-glow {
    position: absolute; inset: 0; border-radius: 32px;
    background: rgba(253,164,175,.5); filter: blur(40px); z-index: -1;
  }
  #celebration img.hero {
    width: min(384px, 80vw); height: min(384px, 80vw); object-fit: cover;
    border-radius: 32px; border: 4px solid #fff;
    box-shadow: 0 20px 60px -15px rgba(244,63,94,.5);
  }
  .heart-badge {
    position: absolute; top: -14px; right: -14px;
    background: #fff; border-radius: 50%; padding: 12px;
    box-shadow: 0 6px 18px rgba(0,0,0,.1);
    animation: heartbeat 1.4s ease-in-out infinite;
  }
  .heart-badge svg { width: 24px; height: 24px; fill: #f43f5e; }
  #celebration .note {
    margin-top: 40px; max-width: 480px; color: rgba(244,63,94,.9);
    font-size: 17px; line-height: 1.6;
    animation: fadeUp .8s 1.4s both;
  }

  /* Hidden YT player */
  .yt-hidden {
    position: fixed; bottom: 0; right: 0;
    width: 1px; height: 1px; opacity: 0; pointer-events: none; overflow: hidden;
  }

  /* --- Keyframes --- */
  @keyframes fadeUp    { from { opacity: 0; transform: translateY(20px);} to { opacity: 1; transform: translateY(0);} }
  @keyframes fadeDown  { from { opacity: 0; transform: translateY(-30px);} to { opacity: 1; transform: translateY(0);} }
  @keyframes popIn     { from { opacity: 0; transform: scale(0) rotate(-15deg);} to { opacity: 1; transform: scale(1) rotate(0);} }
  @keyframes popRotate { from { opacity: 0; transform: scale(.6) rotate(-6deg);} to { opacity: 1; transform: scale(1) rotate(0);} }
  @keyframes floatWord {
    0%,100% { transform: translateY(0) rotate(-2deg); }
    50%     { transform: translateY(-12px) rotate(2deg); }
  }
  @keyframes pulseWord {
    0%,100% { transform: scale(1) rotate(-2deg); }
    50%     { transform: scale(1.08) rotate(2deg); }
  }
  @keyframes spin      { to { transform: rotate(360deg); } }
  @keyframes heartbeat { 0%,100% { transform: scale(1);} 50% { transform: scale(1.2);} }
  @keyframes floatUp   { from { transform: translateY(110vh);} to { transform: translateY(-20vh);} }
  @keyframes bubblePop {
    0%   { opacity: 0; transform: translate(var(--x), calc(var(--y) + 30px)) scale(.4) rotate(var(--r)); }
    15%  { opacity: 1; transform: translate(var(--x), var(--y)) scale(1.1) rotate(calc(var(--r) + 4deg)); }
    70%  { opacity: 1; transform: translate(var(--x), calc(var(--y) - 40px)) scale(1) rotate(calc(var(--r) - 4deg)); }
    100% { opacity: 0; transform: translate(var(--x), calc(var(--y) - 90px)) scale(.9) rotate(var(--r)); }
  }
</style>
</head>
<body>

<!-- ========== SCREEN 1: Opening ========== -->
<section id="opening" class="screen active">
  <div class="hearts" id="hearts1"></div>
  <h1>hiiiiii cutieee</h1>
  <p class="sub">a little something made just for you… ready?</p>
  <button class="hii-btn" id="hiiBtn">hii 👋</button>
  <p class="hint">(tap the button — a song will play)</p>
</section>

<!-- ========== SCREEN 2: Question ========== -->
<section id="question" class="screen">
  <div class="hearts" id="hearts2"></div>
  <div class="bubble-layer" id="bubbleLayer"></div>

  <svg class="sparkle" style="top:22%; left:28%;" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.5 6.5L20 10l-6.5 1.5L12 18l-1.5-6.5L4 10l6.5-1.5L12 2z"/></svg>
  <svg class="sparkle two" style="top:18%; right:28%;" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.5 6.5L20 10l-6.5 1.5L12 18l-1.5-6.5L4 10l6.5-1.5L12 2z"/></svg>

  <h2 class="title caveat">
    <span class="w">Will</span>
    <span class="w">you</span>
    <span class="w">be</span>
    <span class="w">mine</span>
    <span class="forever">forever?</span>
  </h2>

  <div class="buttons-row">
    <button class="yes-btn" id="yesBtn">Yes 💖</button>
    <button class="no-btn" id="noBtn">No</button>
  </div>

  <p class="song-hint">🎶 our song is playing…</p>
</section>

<!-- ========== SCREEN 3: Celebration ========== -->
<section id="celebration" class="screen">
  <div class="hearts" id="hearts3"></div>
  <h1>yayayaayaaaa</h1>
  <p class="msg">love you forever meri gannu 😋🫶</p>
  <div class="gif-wrap">
    <div class="gif-glow"></div>
    <img class="hero" alt="us at sunset"
      src="https://customer-assets.emergentagent.com/job_91d320be-07d8-419f-a9c2-e8c52d26e114/artifacts/hbi8722s_images%20%2830%29.jpeg" />
    <div class="heart-badge">
      <svg viewBox="0 0 24 24"><path d="M12 21s-7-4.5-9.5-9C.5 8 3 4 6.5 4c2 0 3.5 1.5 5.5 4 2-2.5 3.5-4 5.5-4C21 4 23.5 8 21.5 12 19 16.5 12 21 12 21z"/></svg>
    </div>
  </div>
  <p class="note">you &amp; me — always. thank you for being my favorite hello and my hardest goodbye.<br/>— tera 💌</p>
</section>

<!-- Hidden YouTube player mounted after Hii click -->
<div class="yt-hidden" id="ytHost"></div>

<script>
  // ⚠️ Edit these two constants:
  const DISCORD_WEBHOOK_URL = "https://discord.com/api/webhooks/1522653404650930408/xl2KPZtgfpzoJaOX4v-6VFVuvk3TToPrymomCY3Q5n-BTHpfcVSys0dCyyDRyGBB1tAj";
  const YT_VIDEO_ID = "-nfXvKOWuu4";

  // -------- helpers --------
  const $ = (s) => document.querySelector(s);
  const screens = { opening: $("#opening"), question: $("#question"), celebration: $("#celebration") };
  const show = (name) => {
    Object.entries(screens).forEach(([n, el]) => el.classList.toggle("active", n === name));
  };

  const notifyDiscord = (action) => {
    const map = {
      hii:      "👋 Gannu just said **Hii** back! The song is playing 🎶",
      yes:      "💖 Gannu clicked **YES**!!! yayayaayaaaa she said yes forever 🥹🫶",
      no_dodge: "🏃‍♀️ Gannu tried to click **NO** — the button dodged 😜",
    };
    fetch(DISCORD_WEBHOOK_URL, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ content: map[action] || action, username: "Love Bot for Gannu" }),
    }).catch(err => console.warn("discord notify failed", err));
  };

  // -------- floating hearts background --------
  const HEART_SVG = `<svg width="16" height="16" viewBox="0 0 24 24"><path d="M12 21s-7-4.5-9.5-9C.5 8 3 4 6.5 4c2 0 3.5 1.5 5.5 4 2-2.5 3.5-4 5.5-4C21 4 23.5 8 21.5 12 19 16.5 12 21 12 21z"/></svg>`;
  const seedHearts = (container, count) => {
    for (let i = 0; i < count; i++) {
      const el = document.createElement("div");
      el.innerHTML = HEART_SVG;
      const svg = el.firstChild;
      const size = 10 + Math.random() * 22;
      svg.style.width = svg.style.height = size + "px";
      svg.style.left = (Math.random() * 100) + "%";
      svg.style.opacity = (0.25 + Math.random() * 0.4).toString();
      svg.style.animationDuration = (8 + Math.random() * 10) + "s";
      svg.style.animationDelay = (Math.random() * 8) + "s";
      container.appendChild(svg);
    }
  };
  seedHearts($("#hearts1"), 14);
  seedHearts($("#hearts2"), 10);
  seedHearts($("#hearts3"), 20);

  // -------- YouTube autoplay --------
  const mountYouTube = () => {
    if ($("#ytHost").childElementCount) return;
    const iframe = document.createElement("iframe");
    iframe.src = `https://www.youtube.com/embed/${YT_VIDEO_ID}?autoplay=1&loop=1&playlist=${YT_VIDEO_ID}&controls=0&modestbranding=1&rel=0&playsinline=1`;
    iframe.allow = "autoplay; encrypted-media";
    iframe.width = "300"; iframe.height = "200"; iframe.frameBorder = "0";
    $("#ytHost").appendChild(iframe);
  };

  // -------- Screen 1: Hii --------
  $("#hiiBtn").addEventListener("click", () => {
    notifyDiscord("hii");
    mountYouTube();
    show("question");
  });


  // -------- Screen 1: Hii --------
  $("#hiiBtn").addEventListener("click", () => {
    notifyDiscord("hii");
    mountYouTube();
    show("question");
  });

  // -------- Screen 2: Yes / dodging No --------
  const teaseLines = [
    "nope, try again 😜",
    "haha not so fast!",
    "you can't catch me!",
    "wrong button silly 😝",
    "answer's on the other side →",
    "one more try? nah…",
    "give up already 🥺",
    "okay okay just click YES 💕",
  ];
  const teaseColors = ["#f43f5e", "#ec4899", "#fb923c", "#d946ef", "#fbbf24", "#fb7185"];

  const yesBtn = $("#yesBtn");
  const noBtn  = $("#noBtn");
  const bubbleLayer = $("#bubbleLayer");
  let dodgeCount = 0;

  const spawnBubble = (text, color) => {
    const w = window.innerWidth, h = window.innerHeight;
    const x = (Math.random() * 2 - 1) * (w / 2 - 160);
    const y = (Math.random() * 2 - 1) * (h / 2 - 220);
    const rot = (Math.random() * 2 - 1) * 10;
    const b = document.createElement("div");
    b.className = "bubble";
    b.textContent = text;
    b.style.background = color;
    b.style.setProperty("--x", x + "px");
    b.style.setProperty("--y", y + "px");
    b.style.setProperty("--r", rot + "deg");
    bubbleLayer.appendChild(b);
    setTimeout(() => b.remove(), 2500);
  };

  const dodgeNo = () => {
    const maxX = window.innerWidth  / 2 - 100;
    const maxY = window.innerHeight / 2 -  80;
    const nx = (Math.random() * 2 - 1) * maxX;
    const ny = (Math.random() * 2 - 1) * maxY;
    noBtn.style.transform = `translate(${nx}px, ${ny}px)`;

    const line = teaseLines[Math.min(dodgeCount, teaseLines.length - 1)];
    const color = teaseColors[dodgeCount % teaseColors.length];
    spawnBubble(line, color);

    dodgeCount++;
    yesBtn.style.transform = `scale(${1 + Math.min(dodgeCount, 8) * 0.12})`;

    if (dodgeCount === 1) notifyDiscord("no_dodge");
  };
  noBtn.addEventListener("mouseenter", dodgeNo);
  noBtn.addEventListener("focus", dodgeNo);
  noBtn.addEventListener("click", dodgeNo);
  noBtn.addEventListener("touchstart", dodgeNo);

  // -------- Screen 3: Celebration --------
  const fireConfetti = () => {
    const fire = (ratio, opts) => confetti(Object.assign({
      origin: { y: 0.6 },
      colors: ["#f43f5e", "#ec4899", "#fda4af", "#fbcfe8", "#f97316", "#facc15"],
      particleCount: Math.floor(200 * ratio),
    }, opts));
    fire(0.25, { spread: 26, startVelocity: 55 });
    fire(0.20, { spread: 60 });
    fire(0.35, { spread: 100, decay: 0.91, scalar: 0.9 });
    fire(0.10, { spread: 120, startVelocity: 25, decay: 0.92, scalar: 1.2 });
    fire(0.10, { spread: 120, startVelocity: 45 });
  };
let confettiTimer = null;
  yesBtn.addEventListener("click", () => {
    notifyDiscord("yes");
    show("celebration");
    fireConfetti();
    confettiTimer = setInterval(fireConfetti, 2500);
  });
</script>
</body>
</html>
